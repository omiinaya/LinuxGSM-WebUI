# Server configuration
HOST=0.0.0.0
PORT=3331

# Auth
# Secret key for session encryption (generate a random string)
# NEXTAUTH_SECRET=your-secret-here
# For production, also set NEXTAUTH_URL

# Database (file-based, data stored in ./data)
# No external DB required

# Email (for alerts)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=password
# SMTP_FROM=noreply@example.com

# Default admin password (if no users exist)
# DEFAULT_ADMIN_PASSWORD=admin123

# PEPPER for password hashing (optional)
# PEPPER=your-pepper-here

# Node environment
NODE_ENV=production
